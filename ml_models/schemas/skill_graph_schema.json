{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillGraph",
  "description": "Live skill graph updated after every session using ML + EMA smoothing.",
  "type": "object",
  "required": ["child_id", "session_id", "generated_at", "skill_nodes", "summary"],
  "additionalProperties": false,
  "properties": {
    "child_id":     { "type": "string" },
    "session_id":   { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "skill_nodes": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": {
        "type": "object",
        "required": [
          "skill_name", "skill_display_name", "mastery_prob", "mastery_class",
          "previous_mastery", "confidence", "trend", "regression_flagged",
          "reinforcement_need", "prerequisite_skills", "prerequisite_met",
          "unlocked", "evidence_summary", "cold_start", "last_updated", "session_id"
        ],
        "properties": {
          "skill_name":           { "type": "string" },
          "skill_display_name":   { "type": "string" },
          "mastery_prob":         { "type": "number", "minimum": 0, "maximum": 1 },
          "mastery_class":        { "type": "string", "enum": ["low", "developing", "high"] },
          "previous_mastery":     { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence":           { "type": "number", "minimum": 0, "maximum": 1 },
          "trend":                { "type": "string", "enum": ["improving", "stable", "declining"] },
          "regression_flagged":   { "type": "boolean" },
          "reinforcement_need":   { "type": "string", "enum": ["urgent", "high", "moderate", "low"] },
          "prerequisite_skills":  { "type": "array", "items": { "type": "string" } },
          "prerequisite_met":     { "type": "boolean" },
          "unlocked":             { "type": "boolean" },
          "evidence_summary":     { "type": "string" },
          "cold_start":           { "type": "boolean" },
          "last_updated":         { "type": "string", "format": "date-time" },
          "session_id":           { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "skills_mastered", "skills_developing", "skills_need_support",
        "skills_regressing", "skills_unlocked", "overall_progress_pct"
      ],
      "properties": {
        "skills_mastered":      { "type": "array", "items": { "type": "string" } },
        "skills_developing":    { "type": "array", "items": { "type": "string" } },
        "skills_need_support":  { "type": "array", "items": { "type": "string" } },
        "skills_regressing":    { "type": "array", "items": { "type": "string" } },
        "skills_unlocked":      { "type": "array", "items": { "type": "string" } },
        "overall_progress_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
